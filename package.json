{
  "name": "woodcraft-os",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "turbo db:generate",
    "db:push": "npm run --prefix packages/db db:push",
    "db:migrate": "npm run --prefix packages/db db:migrate",
    "db:migrate:prod": "npm run --prefix packages/db db:migrate:prod",
    "db:studio": "npm run --prefix packages/db db:studio",
    "db:reset": "npm run --prefix packages/db db:reset"
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "npm@10.8.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1"
  }
}
